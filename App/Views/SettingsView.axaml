<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="App.Views.SettingsView">
    <StackPanel>
        <Label Content="Story 1: 5"></Label>
        <Label Content="Story 2: 8"></Label>
        <Label Content="Story 3: 13"></Label>
        <Label Content="Story 4: 5"></Label>
        <Label Content="Story 5: 3"></Label>
        <Label Content="Story 6: 2"></Label>
        <Label Content="Story 7: 5"></Label>
        <Label Content="Story 8: 8"></Label>
        <Label Content="Story 9: 8"></Label>
        <Label Content="Story 10: 5"></Label>
        <Label Content="Story 11: 5"></Label>
        <Label Content="Story 12: 5"></Label>
        <Label Content="Story 13: 1"></Label>
    </StackPanel>
</UserControl>